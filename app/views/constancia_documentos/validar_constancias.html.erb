<h1>Validar constancias</h1>

<%= form_for_filterrific @filterrific, html: { id: 'filterrific_form' } do |f| %>
  <div class="row">
    <div class="col-md-12" align="right">
      <br><br><br>
      <% if policy(@constancia_documentos).new? %>
      <%= link_to 'Crear nueva constancia', new_constancia_documento_path, class: 'btn btn-primary' %>
      <% end %>
    </div>
  </div>
  <br>
  <div class="row">
    <div class="col-md-4">
      <%= f.label :search_query, 'Boleta o Apellidos' %>
      <%= f.text_field(
        :search_query,
        class: 'filterrific-periodically-observed form-control col-md-7'
      ) %>
    </div>
    <div class="col-md-4">
      <%= f.label :search_query, 'Escuela' %>
      <%= f.select(
        :unidad_academica,
        @filterrific.select_options[:unidad_academica],
        { include_blank: '- Todas -' },
        class: 'form-control col-md-8'
      ) %>
    </div>
    <div class="col-md-4">
      <%= f.label :search_query, 'Número de relación' %>
      <%= f.select(
        :numero_relacion,
        @filterrific.select_options[:numero_relacion],
        { include_blank: '- Todas -' },
        class: 'form-control col-md-4'
      ) %>
    </div>
    <div class="col-md-4">
  <%= f.label :carrera, 'Carrera' %>
  <%= f.select(
    :carrera,
    ConstanciaDocumento.options_for_carrera,
    { include_blank: '- Todas -' },
    class: 'form-control col-md-4'
  ) %>
</div>
  </div>
  <br>
  <div class="row">
    <div class="col-md-12">
      <%= link_to(
        'Quitar filtros',
        reset_filterrific_url,
        class: 'btn btn-primary'
      ) %>
    </div>
  </div>


  <br>
<% end %>

<script>
  $(document).on('change', '#filterrific_form select', function() {
    $(this).closest('form').submit();
  });
</script>

<%= render(
  partial: 'constancia_documentos/validar_lista',
  locals: { constancia_documentos: @constancia_documentos }
) %>
