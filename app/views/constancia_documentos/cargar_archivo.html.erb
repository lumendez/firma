<% if user_signed_in? && (current_user.role.nombre == 'Dirección' || current_user.role.nombre == 'Administrador' || current_user.role.nombre == 'Departamento' || current_user.role.nombre == 'Captura') %>
  <div class="row" style="float:right">
    <p>
      <strong>Constancias capturadas:</strong> <%= ConstanciaDocumento.all.count %><br>
      <strong>Constancias firmadas:</strong> <%= ConstanciaDocumento.where.not(firma_direccion:nil).count %><br>
      <strong>Constancias por validar:</strong> <%= ConstanciaDocumento.where(constancia_emitida:false,firma_direccion:nil).count %><br>
      <strong>Constancias por firmar:</strong> <%= ConstanciaDocumento.where(firma_direccion:nil).count %>
    </p>
  </div>
<% end %>

<h1>Cargar archivo CSV</h1>

<div class="row">
  <div class="col-md-12">
    <%= form_with url: importar_csv_constancia_documentos_path, local: true, multipart: true do |f| %>
      <div class="form-group">
        <%= f.label :file, "Seleccione archivo CSV" %>
        <%= f.file_field :file, class: "form-control" %>
      </div>

      <div class="form-group">
        <%= f.submit "Importar CSV", class: "btn btn-primary" %>
        <%= link_to 'Cancelar', constancia_documentos_path, class: 'btn btn-secondary' %>
      </div>
    <% end %>
  </div>
</div>

<% if flash[:notice] %>
  <div class="alert alert-success mt-3">
    <%= flash[:notice] %>
  </div>
<% elsif flash[:alert] %>
  <div class="alert alert-danger mt-3">
    <%= flash[:alert] %>
  </div>
<% end %>
